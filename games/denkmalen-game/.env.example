# Draw Battle Environment Variables

# Socket.IO Server URL (for online multiplayer)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Gemini AI API Key (for AI Judge) - Server-side only
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (optional - for user authentication and data persistence)
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# App URL (for sharing links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment
NODE_ENV=development
