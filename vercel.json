{
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=(), usb=(), magnetometer=(), accelerometer=(), gyroscope=(), display-capture=()" },
        { "key": "Content-Security-Policy-Report-Only", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com https://pagead2.googlesyndication.com https://*.googlesyndication.com https://*.google.com https://*.doubleclick.net https://*.supabase.co https://rashid-wep.vercel.app; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.vercel.app https://www.google-analytics.com https://generativelanguage.googleapis.com https://openrouter.ai https://pagead2.googlesyndication.com https://*.googlesyndication.com https://*.doubleclick.net https://*.google.com https://rashid-wep.vercel.app; frame-src 'self' https://*.supabase.co https://pagead2.googlesyndication.com https://www.youtube.com https://youtube.com https://www.tiktok.com https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://www.google.com; worker-src 'self' blob:; media-src 'self' https:; object-src 'none'; base-uri 'self'" }
      ]
    },
    {
      "source": "/(apps|games)/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/king2", "destination": "https://king2-platform.vercel.app/king2" },
    { "source": "/king2/:path*", "destination": "https://king2-platform.vercel.app/king2/:path*" },
    { "source": "/auth/:path*", "destination": "https://king2-platform.vercel.app/king2/auth/:path*" },
    { "source": "/api/auth/:path*", "destination": "https://king2-platform.vercel.app/king2/api/auth/:path*" },
    { "source": "/api/gemini", "destination": "/api/gemini" },
    { "source": "/api/rss", "destination": "/api/rss" },
    { "source": "/api/contact", "destination": "/api/contact" },
    { "source": "/contact", "destination": "/api/contact" },
    { "source": "/apps/calculator-vault", "destination": "/apps/calculator-app" },
    { "source": "/apps/calculator-vault/", "destination": "/apps/calculator-app/" },
    { "source": "/apps/calculator-vault/:path*", "destination": "/apps/calculator-app/:path*" },
    { "source": "/apps/quiz-master", "destination": "/apps/quiz-app" },
    { "source": "/apps/quiz-master/", "destination": "/apps/quiz-app/" },
    { "source": "/apps/quiz-master/:path*", "destination": "/apps/quiz-app/:path*" },
    { "source": "/apps/quran-pro", "destination": "/apps/quran-app" },
    { "source": "/apps/quran-pro/", "destination": "/apps/quran-app/" },
    { "source": "/apps/quran-pro/:path*", "destination": "/apps/quran-app/:path*" },
    { "source": "/admin", "destination": "/admin/login.html" },
    { "source": "/admin/", "destination": "/admin/login.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/offline", "destination": "/offline.html" },
    { "source": "/blog/posts", "destination": "/blog/" },
    { "source": "/blog/feed", "destination": "/blog/rss.xml" },
    { "source": "/blog/index", "destination": "/blog/" },
    { "source": "/games", "destination": "/games/" },
    { "source": "/games/farm-empire", "destination": "/games/farm-game" },
    { "source": "/games/farm-empire/", "destination": "/games/farm-game/" },
    { "source": "/games/farm-empire/:path*", "destination": "/games/farm-game/:path*" },
    { "source": "/games/rust-construction", "destination": "/games/rust-game" },
    { "source": "/games/rust-construction/", "destination": "/games/rust-game/" },
    { "source": "/games/rust-construction/:path*", "destination": "/games/rust-game/:path*" },
    { "source": "/downloads", "destination": "/downloads.html" },
    { "source": "/downloads/", "destination": "/downloads.html" },
    { "source": "/llms.txt", "destination": "/llms.txt" },
    { "source": "/vault/:categoryId/:itemId", "destination": "/vault/:categoryId/index.html" },
    { "source": "/okf", "destination": "/okf/index.md" },
    { "source": "/okf/", "destination": "/okf/index.md" },
    { "source": "/okf/:path*", "destination": "/okf/:path*" }
  ]
}
