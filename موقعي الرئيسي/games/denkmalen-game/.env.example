# Draw Battle Environment Variables

# Socket.IO Server URL (for online multiplayer). Leave unset in normal
# development/production builds — the app defaults to localhost:3000 in dev
# and the deployed Render server in production (see SocketProvider.tsx).
# Only set this to override that, and never set it in a shared .env.local
# that production builds might also read.
# NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Origin allowed to open a Socket.IO connection in production
# (required in production — without it, cross-origin socket connections are rejected)
ALLOWED_ORIGIN=https://your-deployed-domain.com

# Gemini AI API Key (for AI Judge) - Server-side only
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (optional - for user authentication and data persistence)
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Sentry (Error Tracking) - Optional but recommended for production
# Get your DSN from https://sentry.io/
# NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Environment
NODE_ENV=development
