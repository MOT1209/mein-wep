# ── KING2 AI Environment Variables ─────────────────────────

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# AI Providers
OPENROUTER_API_KEY=your_openrouter_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768
ZAI_API_KEY=your_zai_api_key_here

# HuggingFace (optional — for open-source model inference + Hub search)
HF_TOKEN=your_hf_token_here

# Image generation
#   IMAGE_PROVIDER=king2  → use the custom KING2-IMAGE model (needs HF_TOKEN).
#   anything else / unset → free Pollinations.ai (default). KING2 falls back to
#   Pollinations automatically if the custom model fails.
IMAGE_PROVIDER=pollinations
KING2_IMAGE_MODEL=RASHID778/king2-image

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=KING2 AI
