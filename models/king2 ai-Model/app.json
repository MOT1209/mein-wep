{
  "name": "KING2 AI Backend",
  "description": "Python FastAPI backend for KING2 AI platform",
  "env": {
    "GEMINI_API_KEY": { "required": true },
    "GROQ_API_KEY": { "required": true },
    "OPENROUTER_API_KEY": { "required": true },
    "ZAI_API_KEY": { "required": true },
